{
  "scenario": "Test2Alerts: Click on 'Alert with OK' tab. Click the button to display an alert box. Verify alert appears and accept it. Click on 'Alert with OK & Cancel' tab. Click the button to display a confirm box and accept it. Click on 'Alert with Textbox' tab. Click the button to display a prompt box, enter text 'AI Automation' and accept it.",
  "steps": [
    {
      "step": 1,
      "action": "navigate",
      "target": "https://demo.automationtesting.in/Alerts.html"
    },
    {
      "step": 2,
      "action": "fill",
      "target": "promptText",
      "value": "AI Automation"
    },
    {
      "step": 3,
      "action": "assertVisible",
      "target": "page",
      "value": "visible"
    }
  ],
  "env": "qa",
  "applicationUrl": "https://demo.automationtesting.in/Alerts.html",
  "locators": {
    "alertWithOkTab": "a[href='#OKTab']",
    "alertWithOkCancelTab": "a[href='#CancelTab']",
    "alertWithTextboxTab": "a[href='#Textbox']",
    "alertBoxButton": "button.btn-danger",
    "confirmBoxButton": "button.btn-primary",
    "promptBoxButton": "button.btn-info"
  },
  "testData": {
    "promptText": "AI Automation"
  }
}