{
  "scenario": "Banking Application Customer Flow",
  "steps": [
    {
      "action": "navigate",
      "target": "https://www.globalsqa.com/angularJs-protractor/BankingProject/#/login",
      "step": 1,
      "value": ""
    },
    {
      "action": "click",
      "target": "customerLoginButton",
      "step": 2,
      "value": ""
    },
    {
      "action": "select",
      "target": "userSelect",
      "value": "Harry Potter",
      "step": 3
    },
    {
      "action": "click",
      "target": "loginButton",
      "step": 4,
      "value": ""
    },
    {
      "action": "click",
      "target": "depositTab",
      "step": 5,
      "value": ""
    },
    {
      "action": "fill",
      "target": "amountInput",
      "value": "500",
      "step": 6
    },
    {
      "action": "click",
      "target": "depositSubmitButton",
      "step": 7,
      "value": ""
    },
    {
      "action": "assertText",
      "target": "message",
      "value": "Deposit Successful",
      "step": 8
    },
    {
      "action": "click",
      "target": "withdrawTab",
      "step": 9,
      "value": ""
    },
    {
      "action": "fill",
      "target": "amountInput",
      "value": "200",
      "step": 10
    },
    {
      "action": "click",
      "target": "withdrawSubmitButton",
      "step": 11,
      "value": ""
    },
    {
      "action": "assertText",
      "target": "message",
      "value": "Transaction successful",
      "step": 12
    }
  ],
  "env": "default",
  "applicationUrl": "https://www.globalsqa.com/angularJs-protractor/BankingProject/#/login",
  "testData": {
    "userSelect": "Harry Potter",
    "amountInput": "500",
    "message": "Transaction successful"
  }
}